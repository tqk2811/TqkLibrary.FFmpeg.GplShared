<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
	<!--https://docs.microsoft.com/en-us/nuget/reference/nuspec-->
	<metadata>
		<id>TqkLibrary.FFmpeg.Native</id>
		<version>$version$</version>
		<description>FFmpeg Native Libraries $os$ $arch$</description>
		<authors>tqk2811</authors>
		<readme>docs\README.md</readme>
		<projectUrl>https://github.com/tqk2811/TqkLibrary.FFmpeg.GplShared</projectUrl>
		<repository type="git" url="https://github.com/tqk2811/TqkLibrary.FFmpeg.GplShared.git"/>
		<license type="expression">MIT</license>
		<tags>native ffmpeg</tags>
		<contentFiles>
			<files include="**/*.*" copyToOutput="true" buildAction="None"/>
		</contentFiles>
	</metadata>

	<files>
		<file src="README.md" target="docs\" />
		
		<file src="TqkLibrary.FFmpeg.Native.$osName$.$arch$.props" target="build\" />
		<file src="TqkLibrary.FFmpeg.Native.$osName$.$arch$.targets" target="build\" />

		<file src="TqkLibrary.FFmpeg.Native.$osName$.$arch$.props" target="build\native\" />
		<file src="TqkLibrary.FFmpeg.Native.$osName$.$arch$.native.targets" target="build\native\TqkLibrary.FFmpeg.Native.$osName$.$arch$.targets" />

		<file src="$basePath$\bin\*.dll" target="runtimes\$os$-$arch$\native\" />
		<file src="$basePath$\lib\*.lib" target="build\native\$os$\$arch$\lib\" />

		<file src="$basePath$\lib\*.so.*.*" target="runtimes\$os$-$arch$\native\" />
		<file src="$basePath$\lib\*.a" target="build\native\$os$\$arch$\lib\" />

		<file src="$basePath$\include\**\*" target="build\native\include\" />
	</files>
</package>